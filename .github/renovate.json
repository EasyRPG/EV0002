{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Group dependencies from bundler",
      "matchFileNames": ["**/Gemfile"],
      "groupName": "All Gemfile changes",
      "groupSlug": "update-dependencies"
    }
  ],
  "rangeStrategy" : "in-range-only",
  "labels": ["dependencies"],
  "schedule": "monthly"
}
